[Unit]
Description=Dictation hotkey daemon

[Service]
ExecStart=/usr/bin/python3 %h/Documents/Projects/dictation-tool/main.py
WorkingDirectory=%h/Documents/Projects/dictation-tool
Restart=on-failure
Environment=WAYLAND_DISPLAY=wayland-0
Environment=XDG_RUNTIME_DIR=/run/user/1000

[Install]
WantedBy=default.target
